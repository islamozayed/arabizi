{
  "productName": "Franconvert",
  "version": "0.1.0",
  "identifier": "com.franconvert.app",
  "build": {
    "frontendDist": "./ui"
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; script-src 'unsafe-inline'; style-src 'unsafe-inline'; font-src 'self'; img-src data: blob:"
    },
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "overlay",
        "title": "Franconvert",
        "width": 480,
        "height": 352,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "center": true,
        "visible": false,
        "skipTaskbar": true,
        "shadow": true,
        "transparent": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/tray-icon.png",
      "iconAsTemplate": true,
      "tooltip": "Franconvert — Franco Arabic Keyboard"
    }
  },
  "bundle": {
    "macOS": {
      "minimumSystemVersion": "13.0",
      "signingIdentity": null,
      "entitlements": "entitlements.plist"
    }
  }
}
